datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Huesped {
  id               Int      @id @default(autoincrement())
  nombre           String
  tipoDocumento    String
  numeroDocumento  String
  nacionalidad     String
  direccion        String
  lugarProcedencia String
  lugarDestino     String
  telefono         String
  email            String
  motivoViaje      String
  fechaIngreso     String
  fechaSalida      String
  numeroReserva    String   @unique
  creadoEn         DateTime @default(now())

  checkinUrl       String?
  codigoTTLock     String?

  archivoPasaporte String?
  archivoCedula    String?
  archivoFirma     String?

  passcodes        Passcode[]
  traRegistros     TraRegistro[]
}

model Passcode {
  id            Int      @id @default(autoincrement())

  huespedId     Int
  huesped       Huesped  @relation(fields: [huespedId], references: [id], onDelete: Cascade)

  lockId        Int
  lockAlias     String?
  codigo        String?
  keyboardPwdId Int?
  tipo          String
  startDate     BigInt
  endDate       BigInt
  estado        String   @default("ACTIVO")
  ttlockOk      Boolean  @default(true)
  ttlockMessage String?
  creadoEn      DateTime @default(now())

  @@index([huespedId])
  @@index([lockId])
  @@index([keyboardPwdId])
  @@unique([lockId, keyboardPwdId])
}

model CheckinSession {
  id            Int      @id @default(autoincrement())
  numeroReserva String   @unique
  token         String   @unique
  checkinUrl    String?
  payload       Json?
  creadoEn      DateTime @default(now())
  expiracion    DateTime
  usadoEn       DateTime?
  updatedAt     DateTime @updatedAt
}

model TraRegistro {
  id              Int      @id @default(autoincrement())

  huespedId       Int
  huesped         Huesped  @relation(fields: [huespedId], references: [id], onDelete: Cascade)

  numeroReserva   String
  role            String
  endpoint        String
  padreCode       Int?
  code            Int?
  status          String   @default("PENDING")
  attempts        Int      @default(0)
  lastAttemptAt   DateTime?
  requestPayload  Json?
  responsePayload Json?
  errorMessage    String?
  creadoEn        DateTime @default(now())

  @@index([numeroReserva])
  @@index([huespedId])
  @@index([status])
  @@index([endpoint])
}

model Pago {
  id            Int      @id @default(autoincrement())
  numeroReserva String
  huespedId     Int?

  metodo        String
  estado        String   @default("PENDING")

  monto         Float
  moneda        String   @default("COP")

  referencia    String?
  canal         String?
  descripcion   String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  metadata      Json?

  @@index([numeroReserva])
  @@index([estado])
}