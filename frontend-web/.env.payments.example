# ============================================================
# PAYMENT CONFIGURATION — KUYAY HOSTEL
# ============================================================

# ── Feature Flag ──
# Master switch: habilita la sección de pagos en el formulario
VITE_PAYMENT_ENABLED=true

# Si true, BLOQUEA el registro hasta que el pago esté APPROVED
# Para demo/QA dejar en false
VITE_PAYMENT_REQUIRE=false

# Modo: "demo" = mock sin cobros reales | "prod" = conectado a proveedores
VITE_PAYMENT_MODE=demo

# Etiqueta pública que ve el huésped
VITE_PAYMENT_LABEL=Pago seguro

# ── Canales ──
# Bold (pagos en línea: tarjetas, PSE, Nequi)
VITE_CHANNEL_BOLD_ENABLED=true
VITE_BOLD_CHECKOUT_URL=
VITE_BOLD_BUSINESS_NAME=Kuyay Hostel

# Billetero (transferencia/QR) — pendiente de integración
VITE_CHANNEL_BILLETERO_ENABLED=false

# Datáfono (pago presencial) — preparado para integración futura
VITE_CHANNEL_DATAFONO_ENABLED=false

# ── Compatibilidad legacy (se leen como fallback) ──
# VITE_BOLD_ENABLED=true
# VITE_BOLD_REQUIRE_PAYMENT=false
# VITE_BOLD_MODE=demo
# VITE_BOLD_PUBLIC_LABEL=Pago seguro con Bold
# VITE_BOLD_SHOW_COMING_SOON=true
